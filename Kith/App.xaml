<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Kith.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kith"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#111111"/>
            <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#1B1B1B"/>
            <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#D7CFCD"/>

            <SolidColorBrush x:Key="AppBarButtonBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="AppBarButtonForeground" Color="#D7CFCD"/>

            <SolidColorBrush x:Key="AppBarButtonBackgroundPointerOver" Color="#1B1B1B"/>
            <SolidColorBrush x:Key="AppBarButtonForegroundPointerOver" Color="#D7CFCD"/>

            <Color x:Key="BrokenBlack">#1B1B1B</Color>
            <Color x:Key="LighterBrokenBlack">#2b2827</Color>
            <Color x:Key="BrokenWhite">#D7CFCD</Color>
            <Color x:Key="FoxyDark">#963719</Color>

        </ResourceDictionary>
    </Application.Resources>
</Application>
