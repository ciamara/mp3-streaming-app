<?xml version="1.0" encoding="utf-8"?>

<Window
    x:Class="Kith.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kith"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:sources="using:Kith.Sources"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:converters="using:Kith.Converters"
    mc:Ignorable="d"
    Title="Kith">

    <Window.SystemBackdrop>
        <MicaBackdrop />

    </Window.SystemBackdrop>

    <Grid x:Name="LayoutRoot" Background="{StaticResource WindowBackgroundBrush}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="25*"/>
            <ColumnDefinition Width="50*"/>
            <ColumnDefinition Width="25*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>

        <Grid.Resources>
            <converters:CeilingConverter x:Key="DurationCeilingConverter"/>
            <converters:StringJoinConverter x:Key="StringJoinConverter"/>
            <converters:IndexConverter x:Key="IndexConverter"/>
            <converters:IPictureImageConverter x:Key="IPictureImageConverter"/>
            <DataTemplate x:Key="SongListViewTemplate">
                <Grid Padding="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid.ContextFlyout>
                        <MenuFlyout x:Name="SongFlyoutContext">
                            <MenuFlyoutItem Text="add to queue" Click="AddToQueue" Tag="{Binding}"/>
                        </MenuFlyout>
                    </Grid.ContextFlyout>

                    <TextBlock Grid.Column="0" 
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               FontSize="12"
                               Margin="0,0,0,0"
                               Text="{Binding Index, Converter={StaticResource IndexConverter}}" 
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}"/>

                    <Image Grid.Column="1"
                           Source="{Binding Pictures, Converter={StaticResource IPictureImageConverter}}"
                           Width="30" Height="30"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Margin="0,0,0,0"/>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{Binding Title}" 
                                   Style="{StaticResource SubtitleTextBlockStyle}" 
                                   FontSize="12" 
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>

                        <TextBlock Text="{Binding Artists, Converter={StaticResource StringJoinConverter}, ConverterParameter=', '}" 
                                   Style="{StaticResource BodyTextBlockStyle}" 
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Margin="10,0,0,0"
                                   Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <TextBlock Grid.Column="3"
                       VerticalAlignment="Center"
                       FontSize="12" 
                       Text="{Binding Album}"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}"/>

                    <TextBlock Grid.Column="4"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       Margin="10,0,0,0"
                       Text="{Binding Duration, Converter={StaticResource DurationCeilingConverter}}"
                       Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}"/>
                </Grid>
            </DataTemplate>
            <DataTemplate x:Key="CollectionListViewTemplate" x:DataType="sources:Collection">
                <StackPanel Orientation="Horizontal" Padding="5">
                    <Image Source="{Binding collection_cover}" Width="40" Height="40" Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding collection_name}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding collection_description}" FontSize="11" Foreground="Gray"/>
                    </StackPanel>
                </StackPanel>
            </DataTemplate>
            <Style TargetType="AppBarButton">
                <Setter Property="Width" Value="50"/>
                <Setter Property="Height" Value="50"/>
            </Style>
        </Grid.Resources>

        <Grid x:Name="TitleBarContainer" Grid.Row="0" Grid.ColumnSpan="3">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Top"
                    Spacing="0">
                <AppBarButton x:Name="GoBackBtn"
                          Click="GoBackBtn_Click"
                          Margin="0,0,0,0">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Back"/>
                    </AppBarButton.Icon>
                </AppBarButton>

                <AppBarButton x:Name="GoForwardBtn"
                          Click="GoForwardBtn_Click"
                          Margin="0,0,0,0">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Forward"/>
                    </AppBarButton.Icon>
                </AppBarButton>
            </StackPanel>

            <AutoSuggestBox x:Name="MainSearch"
                        PlaceholderText="Search..."
                        TextChanged="MainSearch_TextChanged"
                        QueryIcon="Find"
                        QuerySubmitted="MainSearch_QuerySubmitted"
                        SuggestionChosen="MainSearch_SuggestionChosen"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="300"
                        Height="35"
                        Margin="0,0,0,0" 
                        CornerRadius="22"
                        Background="{ThemeResource ButtonBackgroundBrush}"
                        Foreground="{ThemeResource ButtonForegroundBrush}"
                        BorderBrush="{ThemeResource ButtonBackgroundBrush}"
                        Grid.Column="1">
                <AutoSuggestBox.Resources>
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{StaticResource LighterBrokenBlack}"/>
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="{StaticResource LighterBrokenBlack}"/>
                    <SolidColorBrush x:Key="TextControlBackgroundGotFocus" Color="{StaticResource FoxyDark}"/>
                </AutoSuggestBox.Resources>
            </AutoSuggestBox>

            <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Top"
                    Spacing="0">

                <AppBarButton x:Name="MinimizeBtn"
                          Click="MinimizeBtn_Click">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Remove"/>
                    </AppBarButton.Icon>
                </AppBarButton>

                <AppBarButton x:Name="MaximizeRestoreBtn"
                          Click="MaximizeRestoreBtn_Click">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="FullScreen"/>
                    </AppBarButton.Icon>
                </AppBarButton>

                <AppBarButton x:Name="CloseBtn"
                          Click="CloseBtn_Click">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Cancel"/>
                    </AppBarButton.Icon>
                    <AppBarButton.Resources>
                        <SolidColorBrush x:Key="AppBarButtonBackgroundPointerOver" Color="{StaticResource FoxyDark}"/>
                    </AppBarButton.Resources>
                </AppBarButton>
            </StackPanel>

        </Grid>

        <!--GRADIENT GRID -->
        <Rectangle x:Name="LeftSection"
                       MaxHeight="724" 
                       MaxWidth="373.6"
                       Margin="5,0,5,0"
                       Stroke="Transparent"              
                       Grid.Column="0"
                       Grid.Row="1"
                       RadiusX="50"
                       RadiusY="50"
                       Fill="{ThemeResource ColorDownGradientBrush}"/>

        <Rectangle x:Name="RightSection"
                       MaxHeight="724" 
                       MaxWidth="373.6"
                       Margin="5,0,5,0"
                       Stroke="Transparent"  
                       Grid.Column="2"
                       Grid.Row="1"
                       RadiusX="50"
                       RadiusY="50"
                       Fill="{ThemeResource ColorDownGradientBrush}"/>

        <Rectangle x:Name="BottomSection" 
                   Height="80" 
                   MaxWidth="1530"
                   Margin="5,5,5,5"
                   Stroke="Transparent"  
                   Grid.ColumnSpan="3"
                   Grid.Row="2"
                   RadiusX="30"
                   RadiusY="30"
                   Fill="{ThemeResource ColorUpGradientBrush}"/>

        <Rectangle x:Name="MiddleSection"
                       MaxHeight="724"
                       MaxWidth="768.8"
                       Margin="0,0,0,0"
                       Stroke="Transparent" 
                       Grid.Column="1"
                       Grid.Row="1"
                       RadiusX="50"
                       RadiusY="50"
                       Fill="{ThemeResource ColorDownGradientBrush}"/>

        <Grid x:Name="collectionInfo" Grid.Column="1" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.35*" />
                <RowDefinition Height="1*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0"
                   Grid.Row="0"
                   Source="{Binding SelectedCollection.collection_cover}"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   Margin="25,25,0,0"
                   IsHitTestVisible="True"/>

            <TextBlock Grid.Column="1"
                       Grid.Row="0"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       FontSize="30"
                       FontWeight="ExtraBold"
                       FontFamily="ms-appx:///Assets/Fonts/Montserrat-ExtraBold.ttf#Montserrat"
                       Margin="10,0,0,0"
                       Text="{Binding SelectedCollection.collection_name}"
                       Foreground="White"/>
            
            <TextBlock Grid.Column="1"
                       Grid.Row="0"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Margin="10,50,0,0"
                       FontSize="16"
                       Text="{Binding SelectedCollection.collection_description}"
                       Foreground="{StaticResource BrokenWhite}"/>
            
            <TextBlock Grid.Column="1"
                       Grid.Row="0"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Left"
                       Margin="10,20,0,0"
                       FontSize="11"
                       Foreground="{StaticResource BrokenWhite}">
                <Run Text="{Binding SelectedCollection.collection_size}"/>
                <Run Text="songs,"/>
            </TextBlock>

            <TextBlock Grid.Column="1"
                       Grid.Row="0"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Left"
                       Margin="65,20,0,0"
                       FontSize="11"
                       Foreground="{StaticResource BrokenWhite}">
                <Run Text="{Binding SelectedCollection.collection_duration}"/>
                <Run Text="min"/>
            </TextBlock>
        </Grid>

        <Grid x:Name="midSection" Grid.Column="1" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" />
                <RowDefinition Height="5*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="1" 
                  VerticalAlignment="Top" 
                  HorizontalAlignment="Stretch"
                  Margin="25, 0, 45, 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="#" FontWeight="Light" FontSize="12" Margin="0, 0, 16, 5" HorizontalAlignment="Right"
                   Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}" />
                <TextBlock Grid.Column="1" Text="title" FontWeight="Light" FontSize="12" Margin="0, 0, 0, 5" HorizontalAlignment="Left"
                   Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}" />
                <TextBlock Grid.Column="2" Text="album" FontWeight="Light" FontSize="12" Margin="24, 0, 0, 5" HorizontalAlignment="Left"
                   Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}" />
                <TextBlock Grid.Column="3" Text="duration" FontWeight="Light" FontSize="12" HorizontalAlignment="Right" Margin="10, 0, 18, 5"
                   Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}" />
            </Grid>

            <Rectangle Grid.Row="1"
                       Height="1" 
                       VerticalAlignment="Top"
                       HorizontalAlignment="Stretch"
                       Fill="{StaticResource SystemControlForegroundBaseMediumBrush}"
                       Margin="25, 22, 45, 0"/>

            <!--ALL SONGS VIEW -->
            <ListView x:Name="SongsView"
                          ItemsSource="{Binding AllSongs}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ItemTemplate="{StaticResource SongListViewTemplate}"
                          SelectionMode="Single"
                          SelectedItem="{Binding SelectedSong, Mode=TwoWay}"
                          SelectionChanged="SongsView_SelectionChanged"
                          ShowsScrollingPlaceholders="True"
                          Margin="25, 25, 45, 25"
                          BorderThickness="0"
                          BorderBrush="{StaticResource WindowBackgroundBrush}"
                          Grid.Column="1"
                          Grid.Row="1">
            </ListView>
        </Grid>
        <Grid x:Name="leftSection" Grid.Column="0" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.5*" />
                <RowDefinition Height="1*" />
                <RowDefinition Height="0.75*" />
                <RowDefinition Height="0.75*" />
                <RowDefinition Height="7*" />
            </Grid.RowDefinitions>

            <!--ALL COLLECTIONS VIEW -->
            <ListView x:Name="CollectionsView"
              ItemsSource="{Binding AllCollections}"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              ItemTemplate="{StaticResource CollectionListViewTemplate}"
              SelectionMode="Single"
              SelectedItem="{Binding SelectedCollection, Mode=TwoWay}"
              SelectionChanged="CollectionsView_SelectionChanged"
              ShowsScrollingPlaceholders="True"
              Margin="25, 25, 25, 25"
              BorderThickness="0"
              Grid.Row="4">
            </ListView>

        </Grid>
        <Grid Grid.Column="1" Grid.Row="2" HorizontalAlignment="Center">
            <MediaPlayerElement x:Name="mediaPlayerElement"
                                AutoPlay="False" AreTransportControlsEnabled="True"
                                Background="Transparent">
                <MediaPlayerElement.TransportControls>
                    <MediaTransportControls IsNextTrackButtonVisible="True"
                                            IsPreviousTrackButtonVisible="True"
                                            IsSeekBarVisible="True"
                                            IsSeekEnabled="True"
                                            IsCompact="False"
                                            IsRepeatButtonVisible="True"
                                            IsRepeatEnabled="True"
                                            IsZoomButtonVisible="False"
                                            IsZoomEnabled="False"
                                            HorizontalAlignment="Stretch"
                                            Background="Transparent"
                                            Style="{StaticResource myTransportControlsStyle}">
                    </MediaTransportControls>
                </MediaPlayerElement.TransportControls>
            </MediaPlayerElement>
        </Grid>

        <Grid Grid.Column="2" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" />
                <RowDefinition Height="5*" />
            </Grid.RowDefinitions>

            <Image Grid.Column="2"
                   Grid.Row="0"
                   Source="{Binding SelectedSong.Pictures, Converter={StaticResource IPictureImageConverter}}"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   Margin="0,0,0,0"
                   Tapped="AlbumCoverImage_Tapped" 
                   IsHitTestVisible="True"/>

            <Grid Grid.Column="2" 
                      Grid.Row="1"
                      VerticalAlignment="Stretch" 
                      HorizontalAlignment="Stretch"
                      Margin="0, 10, 0, 20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="5*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0"
                               Grid.Row="0"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="10,0,0,0"
                               Text="title:"
                               Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}"/>
                <TextBox x:Name="titleInput" Grid.Column="1" Grid.Row="0" FontSize="12" FontWeight="SemiBold" Margin="10, 0, 30, 0" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                         Text="{Binding SelectedSong.Title}">
                </TextBox>

                <TextBlock Grid.Column="0"
                               Grid.Row="1"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="10,0,0,0"
                               Text="artists:"
                               Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}"/>
                <TextBox x:Name="artistsInput" Grid.Column="1" Grid.Row="1" FontSize="12" FontWeight="SemiBold" Margin="10, 0, 30, 0" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                         Text="{Binding SelectedSong.Artists, Converter={StaticResource StringJoinConverter}, ConverterParameter=', '}">
                </TextBox>


                <TextBlock Grid.Column="0"
                            Grid.Row="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Margin="10,0,0,0"
                            Text="album:"
                            Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}"/>
                <TextBox x:Name="albumInput" Grid.Column="1" Grid.Row="2" FontSize="12" FontWeight="SemiBold" Margin="10, 0, 30, 0" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                         Text="{Binding SelectedSong.Album}">
                </TextBox>

                <TextBlock Grid.Column="0"
                           Grid.Row="3"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="10,0,0,0"
                           Text="year:"
                           Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}"/>
                <TextBox x:Name="yearInput" Grid.Column="1" Grid.Row="3" FontSize="12" FontWeight="SemiBold" Margin="10, 0, 30, 0" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                         Text="{Binding SelectedSong.Year}">
                </TextBox>

                <TextBlock Grid.Column="0"
                           Grid.Row="4"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="10,0,0,0"
                           Text="track:"
                           Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}"/>
                <TextBox x:Name="trackInput" Grid.Column="1" Grid.Row="4" FontSize="12" FontWeight="SemiBold" Margin="10, 0, 30, 0" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                         Text="{Binding SelectedSong.Track}">
                </TextBox>

                <TextBlock Grid.Column="0"
                           Grid.Row="5"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="10,0,0,0"
                           Text="genres:"
                           Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}"/>
                <TextBox x:Name="genresInput" Grid.Column="1" Grid.Row="5" FontSize="12" FontWeight="SemiBold" Margin="10, 0, 30, 0" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                         Text="{Binding SelectedSong.Genres, Converter={StaticResource StringJoinConverter}, ConverterParameter=', '}">
                </TextBox>

                <Button x:Name="saveTagsButton"
                        Grid.Column="1"
                        Grid.Row="6"
                        Content="save"
                        Click="saveTags" 
                        ClickMode="Release"
                        Margin="0,5,80,0" Width="100"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}"/>
            </Grid>
        </Grid>

    </Grid>

</Window>
