<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Kith.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kith"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Kith">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="LayoutRoot">
        
        <StackPanel HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Orientation="Horizontal"
                    Spacing="0">

            <AppBarButton x:Name="MinimizeBtn"
                          Click="MinimizeBtn_Click"
                          Width="50"
                          Height="50"
                          Margin="-100,0,0,0">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Remove"/>
                </AppBarButton.Icon>
            </AppBarButton>

            <AppBarButton x:Name="MaximizeRestoreBtn"
                          Click="MaximizeRestoreBtn_Click"
                          Width="50"
                          Height="50"
                          Margin="-50,0,0,0">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="FullScreen"/>
                </AppBarButton.Icon>
            </AppBarButton>

            <AppBarButton x:Name="CloseBtn"
                          Click="CloseBtn_Click"
                          Width="50"
                          Height="50"
                          Margin="0,0,0,0">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Cancel"/>
                </AppBarButton.Icon>
            </AppBarButton>
            
        </StackPanel>

        <AutoSuggestBox PlaceholderText="Search..."
                        TextChanged="MainSearch_TextChanged"
                        QueryIcon="Find"
                        QuerySubmitted="MainSearch_QuerySubmitted"
                        SuggestionChosen="MainSearch_SuggestionChosen"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Width="300"
                        Height="35"
                        Margin="0,10,0,0"/>

        <StackPanel HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Orientation="Horizontal"
                    Spacing="0">

            <AppBarButton x:Name="GoBackBtn"
                          Click="GoBackBtn_Click"
                          Width="50"
                          Height="50"
                          Margin="0,0,0,0">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Back"/>
                </AppBarButton.Icon>
            </AppBarButton>

            <AppBarButton x:Name="GoForwardBtn"
                          Click="GoForwardBtn_Click"
                          Width="50"
                          Height="50"
                          Margin="0,0,0,0">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Forward"/>
                </AppBarButton.Icon>
            </AppBarButton>
            
        </StackPanel>
    </Grid>
    
</Window>
