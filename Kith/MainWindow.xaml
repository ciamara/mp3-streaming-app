<?xml version="1.0" encoding="utf-8"?>

<Window
    x:Class="Kith.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kith"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:sources="using:Kith.Sources"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:converters="using:Kith.Converters"
    mc:Ignorable="d"
    Title="Kith">

    <Window.SystemBackdrop>
        <MicaBackdrop />

    </Window.SystemBackdrop>

    <Grid x:Name="LayoutRoot" Background="{StaticResource WindowBackgroundBrush}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="25*"/>
            <ColumnDefinition Width="50*"/>
            <ColumnDefinition Width="25*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <Grid.Resources>
            <converters:CeilingConverter x:Key="DurationCeilingConverter"/>
            <converters:StringJoinConverter x:Key="ArtistJoinConverter"/>
            <converters:IndexFinderConverter x:Key="IndexFinderConverter"/>
            <converters:IPictureImageConverter x:Key="IPictureImageConverter"/>
            <DataTemplate x:Key="SongListViewTemplate">
                <Grid Padding="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" 
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               FontSize="12"
                               Margin="0,0,0,0"
                               Text="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Converter={StaticResource IndexFinderConverter}}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}"/>

                    <Image Grid.Column="1"
                           Source="{Binding Pictures, Converter={StaticResource IPictureImageConverter}}"
                           Width="30" Height="30"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Margin="0,0,0,0"/>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{Binding Title}" 
                                   Style="{StaticResource SubtitleTextBlockStyle}" 
                                   FontSize="12" 
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>

                        <TextBlock Text="{Binding Artists, Converter={StaticResource ArtistJoinConverter}, ConverterParameter=', '}" 
                                   Style="{StaticResource BodyTextBlockStyle}" 
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Margin="10,0,0,0"
                                   Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <TextBlock Grid.Column="3"
                       VerticalAlignment="Center"
                       FontSize="12" 
                       Text="{Binding Album}"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}"/>

                    <TextBlock Grid.Column="4"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       Margin="10,0,0,0"
                       Text="{Binding Duration, Converter={StaticResource DurationCeilingConverter}}"
                       Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}"/>
                </Grid>
            </DataTemplate>
            <Style TargetType="AppBarButton">
                <Setter Property="Width" Value="50"/>
                <Setter Property="Height" Value="50"/>
            </Style>
        </Grid.Resources>

        <Grid x:Name="TitleBarContainer" Grid.Row="0" Grid.ColumnSpan="3">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Top"
                    Spacing="0">
                <AppBarButton x:Name="GoBackBtn"
                          Click="GoBackBtn_Click"
                          Margin="0,0,0,0">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Back"/>
                    </AppBarButton.Icon>
                </AppBarButton>

                <AppBarButton x:Name="GoForwardBtn"
                          Click="GoForwardBtn_Click"
                          Margin="0,0,0,0">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Forward"/>
                    </AppBarButton.Icon>
                </AppBarButton>
            </StackPanel>

            <AutoSuggestBox x:Name="MainSearch"
                        PlaceholderText="Search..."
                        TextChanged="MainSearch_TextChanged"
                        QueryIcon="Find"
                        QuerySubmitted="MainSearch_QuerySubmitted"
                        SuggestionChosen="MainSearch_SuggestionChosen"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="300"
                        Height="35"
                        Margin="0,0,0,0" 
                        CornerRadius="22"
                        Background="{ThemeResource ButtonBackgroundBrush}"
                        Foreground="{ThemeResource ButtonForegroundBrush}"
                        BorderBrush="{ThemeResource ButtonBackgroundBrush}"
                        Grid.Column="1">
                <AutoSuggestBox.Resources>
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{StaticResource LighterBrokenBlack}"/>
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="{StaticResource LighterBrokenBlack}"/>
                    <SolidColorBrush x:Key="TextControlBackgroundGotFocus" Color="{StaticResource FoxyDark}"/>
                </AutoSuggestBox.Resources>
            </AutoSuggestBox>

            <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Top"
                    Spacing="0">

                <AppBarButton x:Name="MinimizeBtn"
                          Click="MinimizeBtn_Click">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Remove"/>
                    </AppBarButton.Icon>
                </AppBarButton>

                <AppBarButton x:Name="MaximizeRestoreBtn"
                          Click="MaximizeRestoreBtn_Click">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="FullScreen"/>
                    </AppBarButton.Icon>
                </AppBarButton>

                <AppBarButton x:Name="CloseBtn"
                          Click="CloseBtn_Click">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Cancel"/>
                    </AppBarButton.Icon>
                    <AppBarButton.Resources>
                        <SolidColorBrush x:Key="AppBarButtonBackgroundPointerOver" Color="{StaticResource FoxyDark}"/>
                    </AppBarButton.Resources>
                </AppBarButton>
            </StackPanel>

        </Grid>

        <!--GRADIENT GRID -->
        <Rectangle x:Name="LeftSection"
                       MaxHeight="724" 
                       MaxWidth="373.6"
                       Margin="5,0,5,0"
                       Stroke="Transparent"              
                       Grid.Column="0"
                       Grid.Row="1"
                       RadiusX="50"
                       RadiusY="50"
                       Fill="{ThemeResource ColorDownGradientBrush}"/>

        <Rectangle x:Name="RightSection"
                       MaxHeight="724" 
                       MaxWidth="373.6"
                       Margin="5,0,5,0"
                       Stroke="Transparent"  
                       Grid.Column="2"
                       Grid.Row="1"
                       RadiusX="50"
                       RadiusY="50"
                       Fill="{ThemeResource ColorDownGradientBrush}"/>

        <Rectangle x:Name="BottomSection" 
                   Height="70" 
                   MaxWidth="1530"
                   Margin="5,5,5,5"
                   Stroke="Transparent"  
                   Grid.ColumnSpan="3"
                   Grid.Row="2"
                   RadiusX="30"
                   RadiusY="30"
                   Fill="{ThemeResource ColorUpGradientBrush}"/>

        <Rectangle x:Name="MiddleSection"
                       MaxHeight="724"
                       MaxWidth="768.8"
                       Margin="0,0,0,0"
                       Stroke="Transparent" 
                       Grid.Column="1"
                       Grid.Row="1"
                       RadiusX="50"
                       RadiusY="50"
                       Fill="{ThemeResource ColorDownGradientBrush}"/>

        <Grid Grid.Column="1" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" />
                <RowDefinition Height="5*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="1" 
                  VerticalAlignment="Top" 
                  HorizontalAlignment="Stretch"
                  Margin="25, 0, 45, 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="#" FontWeight="Light" FontSize="12" Margin="0, 0, 16, 5" HorizontalAlignment="Right"
                   Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}" />
                <TextBlock Grid.Column="1" Text="title" FontWeight="Light" FontSize="12" Margin="0, 0, 0, 5" HorizontalAlignment="Left"
                   Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}" />
                <TextBlock Grid.Column="2" Text="album" FontWeight="Light" FontSize="12" Margin="24, 0, 0, 5" HorizontalAlignment="Left"
                   Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}" />
                <TextBlock Grid.Column="3" Text="duration" FontWeight="Light" FontSize="12" HorizontalAlignment="Right" Margin="10, 0, 18, 5"
                   Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}" />
            </Grid>

            <Rectangle Grid.Row="1"
                       Height="1" 
                       VerticalAlignment="Top"
                       HorizontalAlignment="Stretch"
                       Fill="{StaticResource SystemControlForegroundBaseMediumBrush}"
                       Margin="25, 22, 45, 0"/>

            <!--ALL SONGS VIEW -->
            <ListView x:Name="AllSongsView"
                          ItemsSource="{Binding AllSongs}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ItemTemplate="{StaticResource SongListViewTemplate}"
                          SelectionMode="Single"
                          SelectedItem="{Binding SelectedItem}"
                          ShowsScrollingPlaceholders="True"
                          Margin="25, 25, 45, 25"
                          BorderThickness="0"
                          BorderBrush="{StaticResource WindowBackgroundBrush}"
                          Grid.Column="1"
                          Grid.Row="1">
            </ListView>
        </Grid>

        <Grid Grid.Column="2" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*" />
                <RowDefinition Height="3*" />
            </Grid.RowDefinitions>

            <Image Grid.Column="2"
                   Source="{Binding SelectedItem.Pictures, ElementName=AllSongsView, Converter={StaticResource IPictureImageConverter}}"
                   Width="100" Height="100"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,0,0,0"/>

        </Grid>
    </Grid>

</Window>
